# Configuración unificada para todos los backends
# Archivo .env centralizado para proyectos_alternativos

# ====================================
# URL Base del Servidor
# ====================================
SERVER_URL=https://localhost

# ====================================
# Puertos de los Backends
# ====================================
API_PORT_DIREC=8000
API_PORT_PRO=8001
API_PORT_OLLAMA=8002
API_PORT_FORMULARIO=8003
# ====================================
# URLs de APIs (calculadas)
# ====================================
# chatbot_direc_menu: ${SERVER_URL}:${API_PORT_DIREC}
# uiibot_pro: ${SERVER_URL}:${API_PORT_PRO}
# uiibot_unified: ${SERVER_URL}:${API_PORT_OLLAMA}
# backend_formulario: ${SERVER_URL}:${API_PORT_FORMULARIO}

# ====================================
# Configuración Ollama
# ====================================
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ====================================
# Certificados SSL
# ====================================
#SSL_CERT=/var/www/html/PRUEBA_SITIO/proyectos_alternativos/ssl_certs/cert.pem
#SSL_KEY=/var/www/html/PRUEBA_SITIO/proyectos_alternativos/ssl_certs/key.pem

# ====================================
# Base de Datos (si se necesita)
# ====================================
# DB_PATH=./databases/
