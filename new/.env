# =========================
# Chat Retrieval API - Config
# =========================

# Modelo de embeddings
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Directorio de la knowledge base
KB_DIR=kb_out

# Umbrales de similitud (85% y 82% de confianza mínima)
BASE_THRESHOLD=0.85
REL_THRESHOLD=0.82

# Token de administración para /reload-kb (cámbialo por uno seguro)
ADMIN_TOKEN=
